{
  "info": {
    "_postman_id": "ride-hailing-pooling-test",
    "name": "Ride-Hailing Pooling Test",
    "description": "Collection để test chức năng ghép cuốc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5108",
      "type": "string"
    },
    {
      "key": "token_driver1",
      "value": "",
      "type": "string"
    },
    {
      "key": "token_driver2",
      "value": "",
      "type": "string"
    },
    {
      "key": "trip_id_1",
      "value": "0",
      "type": "number"
    },
    {
      "key": "trip_id_2",
      "value": "0",
      "type": "number"
    },
    {
      "key": "region",
      "value": "South",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1️⃣ AUTH - Login Driver 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"driver1\",\n  \"password\": \"pass123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.variables.set('token_driver1', jsonData.accessToken);",
              "  pm.variables.set('user_id_1', jsonData.user.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "1️⃣ AUTH - Login Driver 2",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"driver2\",\n  \"password\": \"pass123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.variables.set('token_driver2', jsonData.accessToken);",
              "  pm.variables.set('user_id_2', jsonData.user.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2️⃣ TRIPS - Book Trip 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver1}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userID\": 1,\n  \"pickupLocation\": \"10.7605,106.7035\",\n  \"dropoffLocation\": \"10.8,106.8\",\n  \"region\": \"{{region}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/trips/book-trip",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "book-trip"
          ]
        },
        "description": "Book trip 1 với pickup gần Tân Bình, dropoff gần Phú Nhuận"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.variables.set('trip_id_1', jsonData.tripId);",
              "  console.log('Trip 1 ID: ' + jsonData.tripId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2️⃣ TRIPS - Book Trip 2 (Nearby)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver2}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userID\": 2,\n  \"pickupLocation\": \"10.7610,106.7040\",\n  \"dropoffLocation\": \"10.8010,106.8010\",\n  \"region\": \"{{region}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/trips/book-trip",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "book-trip"
          ]
        },
        "description": "Book trip 2 với pickup gần trip 1 (<1km), dropoff cũng gần trip 1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.variables.set('trip_id_2', jsonData.tripId);",
              "  console.log('Trip 2 ID: ' + jsonData.tripId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3️⃣ POOLING - Get Pool Candidates for Trip 1",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver1}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/trips/pool-candidates/{{trip_id_1}}?mainPickupLat=10.7605&mainPickupLon=106.7035&mainDropoffLat=10.8&mainDropoffLon=106.8",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "pool-candidates",
            "{{trip_id_1}}"
          ],
          "query": [
            {
              "key": "mainPickupLat",
              "value": "10.7605"
            },
            {
              "key": "mainPickupLon",
              "value": "106.7035"
            },
            {
              "key": "mainDropoffLat",
              "value": "10.8"
            },
            {
              "key": "mainDropoffLon",
              "value": "106.8"
            }
          ]
        },
        "description": "Tìm các cuốc có thể ghép với Trip 1 - tiêu chí: pickup <= 1km, dropoff <= 1km, time <= 5 min"
      }
    },
    {
      "name": "4️⃣ POOLING - Pool Trip 1 with Trip 2",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver1}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"MainTripID\": {{trip_id_1}},\n  \"SecondaryTripID\": {{trip_id_2}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/trips/pool",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "pool"
          ]
        },
        "description": "Ghép Trip 1 và Trip 2 lại - cả 2 hành khách sẽ nhận thông báo"
      }
    },
    {
      "name": "5️⃣ POOLING - Get Pooled Trip Info",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver1}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/trips/pooled/{{trip_id_1}}",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "pooled",
            "{{trip_id_1}}"
          ]
        },
        "description": "Xem thông tin chi tiết cuốc ghép (main trip + secondary trip + passengers count)"
      }
    },
    {
      "name": "HEALTH - Check API Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/trips/health/{{region}}",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "health",
            "{{region}}"
          ]
        },
        "description": "Kiểm tra trạng thái Primary/Replica DB"
      }
    },
    {
      "name": "PENDING - Get Pending Trips",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_driver1}}"
          },
          {
            "key": "X-Region",
            "value": "{{region}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/trips/pending/{{region}}",
          "protocol": "http",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "trips",
            "pending",
            "{{region}}"
          ]
        },
        "description": "Lấy danh sách tất cả cuốc đang chờ (Pending status)"
      }
    }
  ]
}
