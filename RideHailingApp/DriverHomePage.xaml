<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RideHailingApp"
    xmlns:services="clr-namespace:RideHailingApp.Services"
    x:Class="RideHailingApp.DriverHomePage"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0F1117"
    Title="Nhận cuốc">

    <Grid RowDefinitions="Auto,*">

        <!-- ===== HEADER (outside tabs) ===== -->
        <VerticalStackLayout Grid.Row="0" Padding="20,48,20,0" Spacing="16">

            <!-- Avatar + Name + Status Badge -->
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Border BackgroundColor="#00C853"
                        StrokeThickness="0"
                        WidthRequest="52" HeightRequest="52"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26"/>
                    </Border.StrokeShape>
                    <Label x:Name="AvatarLabel"
                           Text="T"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                    <Label x:Name="DriverNameLabel"
                           Text="Tài xế"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="Chế độ Tài xế"
                           FontSize="12"
                           TextColor="#4A5068"/>
                </VerticalStackLayout>

                <Border x:Name="StatusBadge"
                        Grid.Column="2"
                        BackgroundColor="#1A2A1A"
                        StrokeThickness="1"
                        Stroke="#00C853"
                        Padding="10,6"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label x:Name="StatusLabel"
                           Text="● Offline"
                           TextColor="#4A5068"
                           FontSize="12"
                           FontAttributes="Bold"/>
                </Border>
            </Grid>

            <!-- Vehicle Info -->
            <Border BackgroundColor="#13161F"
                    StrokeThickness="1"
                    Stroke="#2E3348"
                    Padding="16,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Label Text="🚗" FontSize="28" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label x:Name="VehicleTypeLabel"
                               Text="Loại xe: —"
                               TextColor="#8A8FA3"
                               FontSize="13"/>
                        <Label x:Name="VehiclePlateLabel"
                               Text="Biển số: —"
                               TextColor="White"
                               FontSize="14"
                               FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Error Banner -->
            <Border x:Name="ErrorBanner"
                    IsVisible="False"
                    BackgroundColor="#2A1A1A"
                    StrokeThickness="1"
                    Stroke="#FF5252"
                    Padding="14,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Label x:Name="ErrorLabel"
                       Text=""
                       TextColor="#FF5252"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </Border>

            <!-- Online Toggle Button -->
            <Button x:Name="OnlineToggleButton"
                    Text="🚦 Bắt đầu nhận cuốc xe"
                    BackgroundColor="#00C853"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="17"
                    CornerRadius="16"
                    HeightRequest="60"
                    Clicked="OnGoOnlineClicked"/>

            <!-- Status Info Card -->
            <Border BackgroundColor="#1C1F2E"
                    StrokeThickness="1"
                    Stroke="#2E3348"
                    Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Trạng thái" TextColor="#4A5068" FontSize="11" HorizontalOptions="Center"/>
                        <Label x:Name="StatusInfoLabel"
                               Text="Offline"
                               TextColor="#8A8FA3"
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label Text="Cuốc đang chờ" TextColor="#4A5068" FontSize="11" HorizontalOptions="Center"/>
                        <Label x:Name="PendingCountLabel"
                               Text="0"
                               TextColor="#00C853"
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>

        <!-- ===== TAB AREA ===== -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,16,0,0">

            <!-- Tab Header Bar -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*" BackgroundColor="#13161F">

                <!-- Tab 1: Nhận Cuốc -->
                <VerticalStackLayout Grid.Column="0" Spacing="0">
                    <Button x:Name="Tab1Button"
                            Text="Nhận Cuốc"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="14"
                            HeightRequest="48"
                            Clicked="OnTab1Clicked"/>
                    <BoxView x:Name="Tab1Indicator"
                             BackgroundColor="#00C853"
                             HeightRequest="3"/>
                </VerticalStackLayout>

                <!-- Tab 2: Ghép Cuốc -->
                <VerticalStackLayout Grid.Column="1" Spacing="0">
                    <Button x:Name="Tab2Button"
                            Text="Ghép Cuốc 🚗"
                            BackgroundColor="Transparent"
                            TextColor="#4A5068"
                            FontSize="14"
                            HeightRequest="48"
                            Clicked="OnTab2Clicked"/>
                    <BoxView x:Name="Tab2Indicator"
                             BackgroundColor="Transparent"
                             HeightRequest="3"/>
                </VerticalStackLayout>

            </Grid>

            <!-- Tab 1 Content: Nhận Cuốc -->
            <ScrollView x:Name="Tab1Content" Grid.Row="1">
                <VerticalStackLayout Padding="20,16,20,24" Spacing="16">

                    <!-- Active Trip Card -->
                    <Border x:Name="ActiveTripCard"
                            IsVisible="False"
                            BackgroundColor="#1C1F2E"
                            StrokeThickness="1"
                            Stroke="#00C853"
                            Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Chuyến đang thực hiện"
                                   TextColor="#00C853"
                                   FontSize="14"
                                   FontAttributes="Bold"/>
                            <Label x:Name="ActiveTripInfoLabel"
                                   Text=""
                                   TextColor="#8A8FA3"
                                   FontSize="13"/>
                            <Label x:Name="ActiveTripStatusLabel"
                                   Text="🚗 Đang trên đường đến điểm đón"
                                   TextColor="#FFC107"
                                   FontSize="12"
                                   HorizontalOptions="Center"/>

                            <Button x:Name="ArriveButton"
                                    Text="📍 Đã đến điểm đón"
                                    BackgroundColor="#1565C0"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="46"
                                    Clicked="OnArriveClicked"/>

                            <Button x:Name="PickupButton"
                                    Text="🧑 Đã đón khách"
                                    IsVisible="False"
                                    BackgroundColor="#E65100"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="46"
                                    Clicked="OnPickupClicked"/>

                            <Button x:Name="CompleteButton"
                                    Text="✅ Hoàn thành chuyến"
                                    IsVisible="False"
                                    BackgroundColor="#2E7D32"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="46"
                                    Clicked="OnCompleteClicked"/>

                            <Button x:Name="DriverCancelButton"
                                    Text="Hủy cuốc"
                                    BackgroundColor="Transparent"
                                    TextColor="#FF5252"
                                    FontSize="13"
                                    Clicked="OnDriverCancelTripClicked"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Pending Trips List -->
                    <Label Text="Cuốc xe đang chờ"
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"
                           Margin="0,4,0,0"/>

                    <CollectionView x:Name="TripListView"
                                    ItemsSource="{Binding TripRequests}"
                                    SelectionMode="None">
                        <CollectionView.EmptyViewTemplate>
                            <DataTemplate>
                                <Label Text="Chưa có cuốc xe nào. Bật nhận cuốc để xem danh sách."
                                       TextColor="#4A5068"
                                       FontSize="13"
                                       HorizontalOptions="Center"
                                       Margin="0,20"/>
                            </DataTemplate>
                        </CollectionView.EmptyViewTemplate>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="services:PendingTripItem">
                                <Border BackgroundColor="#1C1F2E"
                                        StrokeThickness="1"
                                        Stroke="#2E3348"
                                        Padding="14,12"
                                        Margin="0,0,0,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="📍" FontSize="13" VerticalOptions="Center"/>
                                            <Label Text="{Binding PickupLocation}"
                                                   TextColor="White"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Grid.Row="1" Spacing="8">
                                            <Label Text="🏁" FontSize="13" VerticalOptions="Center"/>
                                            <Label Text="{Binding DropoffLocation}"
                                                   TextColor="#8A8FA3"
                                                   FontSize="13"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Grid.Row="2" Spacing="8">
                                            <Label Text="{Binding DisplayVehicle}"
                                                   TextColor="#FFC107"
                                                   FontSize="11"/>
                                            <Label Text="•" TextColor="#4A5068" FontSize="11"/>
                                            <Label Text="{Binding DisplayFare}"
                                                   TextColor="#00C853"
                                                   FontSize="11"
                                                   FontAttributes="Bold"/>
                                        </HorizontalStackLayout>
                                        <Button Grid.Column="1"
                                                Grid.RowSpan="3"
                                                Text="Nhận"
                                                BackgroundColor="#00C853"
                                                TextColor="White"
                                                FontAttributes="Bold"
                                                FontSize="13"
                                                CornerRadius="10"
                                                WidthRequest="72"
                                                HeightRequest="52"
                                                VerticalOptions="Center"
                                                CommandParameter="{Binding TripID}"
                                                Clicked="OnAcceptTripClicked"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Tab 2 Content: Ghép Cuốc -->
            <ScrollView x:Name="Tab2Content" Grid.Row="1" IsVisible="False">
                <local:PoolingTabView x:Name="PoolingTab"/>
            </ScrollView>

        </Grid>

    </Grid>

</ContentPage>
