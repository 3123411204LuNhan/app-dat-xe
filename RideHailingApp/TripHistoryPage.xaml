<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RideHailingApp"
    x:Class="RideHailingApp.TripHistoryPage"
    Shell.NavBarIsVisible="False"
    Title="Lịch sử chuyến"
    BackgroundColor="{AppThemeBinding Dark=#0F1117, Light=#F5F5F5}">

    <ContentPage.Resources>
        <local:HexToColorConverter x:Key="HexToColor"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Dark=#13161F, Light=#FFFFFF}" Padding="20,52,20,16">
            <Label Text="Lịch sử chuyến đi"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Dark=White, Light=#111111}"/>
            <Label Text="Tất cả các chuyến đi của bạn"
                   FontSize="13"
                   TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}"/>
        </VerticalStackLayout>

        <!-- Banner READ-ONLY -->
        <Border Grid.Row="1"
                x:Name="ReadOnlyBanner"
                IsVisible="False"
                BackgroundColor="#2A2200"
                StrokeThickness="1"
                Stroke="#FFC107"
                Padding="16,12"
                Margin="16,10,16,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="4">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="⚠️" FontSize="14" VerticalOptions="Center"/>
                    <Label Text="Đang kết nối server dự phòng (Replica)"
                           TextColor="#FFC107" FontSize="14" FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
                <Label Text="Server chính tạm thời không khả dụng. Bạn chỉ có thể xem lịch sử — không thể đặt chuyến mới."
                       TextColor="#C49A00" FontSize="12"/>
                <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                    <Label Text="●" TextColor="#FFC107" FontSize="10" VerticalOptions="Center"/>
                    <Label x:Name="ReplicaServerLabel"
                           Text="replica-hcm:5433"
                           TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="11" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Danh sách chuyến đi -->
        <CollectionView Grid.Row="2"
                        x:Name="TripList"
                        Margin="16,12,16,0">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="40">
                    <Label Text="🚗" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Chưa có chuyến đi nào"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Dark=White, Light=#111111}" HorizontalOptions="Center"/>
                    <Label Text="Đặt chuyến đầu tiên của bạn ngay!"
                           FontSize="13" TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{AppThemeBinding Dark=#1C1F2E, Light=#EEEEEE}"
                            StrokeThickness="0"
                            Padding="16,14"
                            Margin="0,0,0,10">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                            <!-- Row 0: Trạng thái + Ngày + Giá -->
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Padding="8,4" StrokeThickness="0"
                                        BackgroundColor="{Binding StatusColor, Converter={StaticResource HexToColor}}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding StatusText}"
                                           TextColor="White" FontSize="12" FontAttributes="Bold"/>
                                </Border>
                                <Label Grid.Column="1"
                                       Text="{Binding DateText}"
                                       TextColor="{AppThemeBinding Dark=#4A5068, Light=#666666}" FontSize="12"
                                       VerticalOptions="Center" Margin="10,0,0,0"/>
                                <Label Grid.Column="2"
                                       Text="{Binding PriceText}"
                                       TextColor="{AppThemeBinding Dark=White, Light=#111111}" FontSize="16"
                                       FontAttributes="Bold" VerticalOptions="Center"/>
                            </Grid>

                            <!-- Row 1: Loại xe -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="6">
                                <Label Text="🛵" FontSize="13" VerticalOptions="Center"/>
                                <Label Text="{Binding VehicleType}"
                                       TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}"
                                       FontSize="12" VerticalOptions="Center"/>
                            </HorizontalStackLayout>

                            <!-- Row 2: Điểm đón - Điểm đến -->
                            <VerticalStackLayout Grid.Row="2" Spacing="8">
                                <Grid ColumnDefinitions="20,*">
                                    <Label Text="📍" FontSize="14" VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding StartAddress}"
                                           TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="13"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Dark=#2E3348, Light=#CCCCCC}" Margin="20,0,0,0"/>
                                <Grid ColumnDefinitions="20,*">
                                    <Label Text="🏁" FontSize="14" VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding DestAddress}"
                                           TextColor="{AppThemeBinding Dark=White, Light=#111111}" FontSize="13"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Row 3: Tài xế + Rating + Nút đánh giá -->
                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,Auto">
                                <Border BackgroundColor="#252A3A" StrokeThickness="0"
                                        WidthRequest="30" HeightRequest="30">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="15"/></Border.StrokeShape>
                                    <Label Text="{Binding DriverInitial}" TextColor="{AppThemeBinding Dark=White, Light=#111111}"
                                           FontSize="13" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1"
                                       Text="{Binding DriverName}"
                                       TextColor="{AppThemeBinding Dark=#8A8FA3, Light=#555555}" FontSize="13"
                                       VerticalOptions="Center" Margin="8,0,0,0"/>
                                <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center" Margin="0,0,8,0">
                                    <Label Text="⭐" FontSize="13"/>
                                    <Label Text="{Binding Rating}" TextColor="#FFC107" FontSize="13"/>
                                </HorizontalStackLayout>
                                <Button Grid.Column="3"
                                        Text="Đánh giá"
                                        IsVisible="{Binding CanRate}"
                                        CommandParameter="{Binding TripId}"
                                        Clicked="OnRateButtonClicked"
                                        BackgroundColor="#FFC107"
                                        TextColor="#111111"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        Padding="10,5"
                                        CornerRadius="8"
                                        HeightRequest="32"/>
                            </Grid>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
